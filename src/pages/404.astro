---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Not Found">
	<div class="error-container">
		<div class="error-icon">🛸</div>
		<h1>404: Page Not Found</h1>
		<p>The resource you are looking for doesn't exist or hasn't been indexed yet.</p>
		<a href="/" class="btn-fluent">Return Home</a>
	</div>
</Layout>

<style is:global>
	.error-container {
		text-align: center;
		padding: 4rem 0;
	}
	
	.error-icon {
		font-size: 4rem;
		margin-bottom: 1.5rem;
	}

	.error-container h1 {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}

	.error-container p {
		color: var(--text-secondary);
		font-size: 1.1rem;
		margin-bottom: 2rem;
		max-width: 400px;
		margin-left: auto;
		margin-right: auto;
	}
</style>
