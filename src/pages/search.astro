---
import Layout from '../layouts/Layout.astro';
import indexedFiles from '../data/search-index.json';

const q = Astro.url.searchParams.get('q');
const origin = Astro.url.origin;
const REPO_URL = "https://github.com/InledGroup/mdpedia";
let results = [];

if (q) {
  const searchQ = q.toLowerCase();
  if (searchQ.endsWith('*')) {
    const prefix = searchQ.slice(0, -1);
    results = indexedFiles.filter(item => 
      item.slug.toLowerCase().startsWith(prefix)
    );
  } else {
    results = indexedFiles.filter(item => 
      item.slug.toLowerCase().includes(searchQ) || 
      item.title.toLowerCase().includes(searchQ)
    );
  }
}

const acceptHeader = Astro.request.headers.get('accept') || '';
const userAgent = Astro.request.headers.get('user-agent') ? Astro.request.headers.get('user-agent').toLowerCase() : '';

const isJsonRequested = acceptHeader.includes('application/json');
const isMarkdownRequested = acceptHeader.includes('text/markdown') || 
(userAgent.includes('curl') || userAgent.includes('fetch') || userAgent.includes('agent') || userAgent.includes('bot'));

// Handle Agent responses (Markdown or JSON)
if (isJsonRequested || isMarkdownRequested) {
    if (results.length === 0) {
        const instructions = "# Documentation Not Found\n\nNo results found for \"" + q + "\". To request indexing, open a GitHub Issue with the URL as title.";
        return new Response(isJsonRequested ? JSON.stringify({ error: 'Not found', instructions }) : instructions, {
            headers: { 'Content-Type': isJsonRequested ? 'application/json' : 'text/markdown' }
        });
    }

    if (isJsonRequested) {
        return new Response(JSON.stringify(results), {
            headers: { 'Content-Type': 'application/json' }
        });
    }

    // Default to Markdown for agents
    let mdResults = "# Search results for: " + q + "\n\n";
    results.forEach(r => {
        mdResults += "- [" + r.title + "](" + origin + r.raw + ")\n";
    });
    return new Response(mdResults, {
        headers: { 'Content-Type': 'text/markdown' }
    });
}

// GitHub Issue URL generation logic
const isUrl = q && q.startsWith('http');
const githubIssueTitle = isUrl ? q : ("https://" + q);
const githubIssueUrl = REPO_URL + "/issues/new?title=" + encodeURIComponent(githubIssueTitle);
---

<Layout title={q ? ("Search: " + q) : "Search"}>
	<div class="search-header">
		<a href="/" class="back-link">
			<i class="fa-solid fa-arrow-left-long"></i> Back to home
		</a>
		<h1 class="fluent-h1">Results for "{q}"</h1>
	</div>

	{results.length > 0 ? (
		<div class="results-container">
			<div class="card-grid">
				{results.map(res => (
					<a href={res.path} class="doc-card">
						<div class="card-icon">
							<i class={res.slug.includes('_index') ? "fa-solid fa-book" : "fa-solid fa-file-lines"}></i>
						</div>
						<div class="card-content">
							<span class="doc-title">{res.title}</span>
							<span class="doc-slug">{res.slug}</span>
						</div>
					</a>
				))}
			</div>
		</div>
	) : (
		<div class="no-results">
			<div class="empty-state">
				<i class="fa-solid fa-magnifying-glass empty-icon"></i>
				<h2>No results found</h2>
				<p>We couldn't find any documentation matching your search.</p>
			</div>

			<div class="index-request-card">
				<div class="request-content">
					<div class="request-icon">
						<i class="fa-solid fa-cloud-arrow-up"></i>
					</div>
					<div class="request-text">
						<h3>Want to index this resource?</h3>
						<p>You can request immediate indexing of this URL via our automated GitHub system.</p>
					</div>
				</div>
				<div class="request-action">
					<a href={githubIssueUrl} class="btn-fluent" target="_blank">
						<i class="fa-brands fa-github"></i> Request Indexing
					</a>
				</div>
			</div>
		</div>
	)}
</Layout>

<style is:global>
	.search-header {
		margin-bottom: 3.5rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
		font-size: 0.95rem;
		color: var(--text-secondary);
		font-weight: 600;
	}

	.fluent-h1 {
		font-size: 2.75rem;
		margin: 0;
		color: var(--text-main);
		font-weight: 800;
		letter-spacing: -0.5px;
	}

	.no-results {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.index-request-card {
		background: rgba(255, 255, 255, 0.5);
		padding: 3rem;
		border-radius: 32px;
		border: 1px solid var(--glass-border);
		box-shadow: var(--shadow-fluent);
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 2rem;
		flex-wrap: wrap;
	}

	.request-content {
		display: flex;
		align-items: center;
		gap: 2rem;
		flex: 1;
		min-width: 300px;
	}

	.request-icon {
		width: 72px;
		height: 72px;
		background: rgba(245, 131, 62, 0.1);
		color: var(--primary);
		border-radius: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
	}

	.request-text h3 {
		margin: 0;
		font-size: 1.75rem;
		font-weight: 800;
		color: var(--text-main);
	}

	.request-text p {
		margin: 0.5rem 0 0;
		color: var(--text-secondary);
		font-size: 1.1rem;
		line-height: 1.6;
	}

	@media (max-width: 800px) {
		.index-request-card {
			flex-direction: column;
			text-align: center;
			padding: 2rem;
		}
		.request-content {
			flex-direction: column;
			min-width: unset;
		}
	}
</style>
