---
import Layout from '../layouts/Layout.astro';
import indexedFiles from '../data/search-index.json';

const q = Astro.url.searchParams.get('q');
const origin = Astro.url.origin;
const REPO_URL = "https://github.com/InledGroup/mdpedia";
let results = [];

if (q) {
  const searchQ = q.toLowerCase();
  if (searchQ.endsWith('*')) {
    const prefix = searchQ.slice(0, -1);
    results = indexedFiles.filter(item => 
      item.slug.toLowerCase().startsWith(prefix)
    );
  } else {
    results = indexedFiles.filter(item => 
      item.slug.toLowerCase().includes(searchQ) || 
      item.title.toLowerCase().includes(searchQ)
    );
  }
}

const acceptHeader = Astro.request.headers.get('accept') || '';
const userAgent = Astro.request.headers.get('user-agent')?.toLowerCase() || '';

const isJsonRequested = acceptHeader.includes('application/json');
const isMarkdownRequested = acceptHeader.includes('text/markdown') || 
user_agent_check();

function user_agent_check() {
    return userAgent.includes('curl') || 
           userAgent.includes('fetch') || 
           userAgent.includes('agent') || 
           userAgent.includes('bot');
}

// Handle Agent responses (Markdown or JSON)
if (isJsonRequested || isMarkdownRequested) {
    const instructions = `# 🔍 Documentation Not Found

No results found for "${q}". If you want to index a new resource, follow these instructions:

## 🤖 Instructions to request indexing:

1. **Create an Issue** in our GitHub repository: ${REPO_URL}
2. The **Title** of the Issue must be the **Full URL** (e.g., https://docs.example.com).
3. The system will process it automatically in less than 60 seconds.

### Fast Method (GitHub CLI):
\`\`\`bash
gh issue create --repo InledGroup/mdpedia --title "YOUR_URL_HERE" --body "Auto-indexing request generated by AI Agent."
\`\`\`

Read our full capabilities at ${origin}/skill.md
`;

    if (results.length === 0) {
        return new Response(isJsonRequested ? JSON.stringify({ error: 'Not found', instructions }) : instructions, {
            headers: { 'Content-Type': isJsonRequested ? 'application/json' : 'text/markdown' }
        });
    }

    if (isJsonRequested) {
        return new Response(JSON.stringify(results), {
            headers: { 'Content-Type': 'application/json' }
        });
    }

    // Default to Markdown for agents
    const mdResults = `# 🔍 Search results for: ${q}\n\n` + 
          results.map(r => `- [${r.title}](${origin}${r.raw}) (Slug: ${r.slug})`).join('\n') +
          `\n\nTotal results: ${results.length}`;
    
    return new Response(mdResults, {
        headers: { 'Content-Type': 'text/markdown' }
    });
}
---

<Layout title={`Search: ${q}`}>
	<div class="search-header">
		<a href="/" class="back-link">← Back to home</a>
		<h1>Search Results for "{q}"</h1>
	</div>
	
	{results.length > 0 ? (
		<div class="results-container">
			<ul class="results-list">
				{results.map(res => (
					<li>
						<a href={res.path} class="result-item">
							<span class="result-title">{res.title}</span>
							<span class="result-slug">{res.slug}</span>
						</a>
					</li>
				))}
			</ul>
		</div>
	) : (
		<div class="no-results">
			<div class="no-results-icon">🔍</div>
			<p>No local results found for your search.</p>
			
			<div class="index-request">
				<h2>Want to index a new resource?</h2>
				<p>If you're looking for a specific URL that isn't in our database, you can request its immediate indexing via GitHub.</p>
				<a href={`${REPO_URL}/issues/new?title=${encodeURIComponent(q?.startsWith('http') ? q : 'https://')}`} class="btn-fluent" target="_blank">
					Request Indexing on GitHub
				</a>
			</div>
		</div>
	)}
</Layout>

<style is:global>
	.search-header {
		margin-bottom: 2.5rem;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1rem;
		font-size: 0.9rem;
		color: var(--text-secondary);
	}

	.search-header h1 {
		font-size: 2.25rem;
		margin: 0;
		font-weight: 800;
	}

	.results-container {
		margin-top: 1rem;
	}

	.results-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.result-item {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 1.25rem 1.75rem;
		background: rgba(255, 255, 255, 0.4);
		border-radius: 16px;
		border: 1px solid rgba(255, 255, 255, 0.5);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		text-decoration: none;
	}

	.result-item:hover {
		border-color: var(--primary);
		transform: translateX(10px);
		background: white;
		box-shadow: 0 10px 20px rgba(0,0,0,0.03);
	}

	.result-title {
		font-weight: 700;
		font-size: 1.15rem;
		color: var(--text-main);
	}

	.result-slug {
		font-size: 0.85rem;
		color: var(--text-secondary);
		font-family: 'Segoe UI Mono', 'Roboto Mono', monospace;
		opacity: 0.8;
	}

	.no-results {
		padding: 4rem 2rem;
		text-align: center;
		background: rgba(255, 255, 255, 0.3);
		border-radius: 32px;
		border: 1px dashed rgba(0,0,0,0.1);
	}

	.no-results-icon {
		font-size: 3.5rem;
		margin-bottom: 1rem;
		opacity: 0.4;
	}

	.no-results p {
		font-size: 1.15rem;
		color: var(--text-secondary);
	}

	.index-request {
		margin-top: 3rem;
		padding-top: 3rem;
		border-top: 1px solid rgba(0, 0, 0, 0.05);
	}

	.index-request h2 {
		font-size: 1.6rem;
		margin-bottom: 1rem;
		font-weight: 700;
	}

	.index-request p {
		max-width: 500px;
		margin: 0 auto 1.75rem;
		font-size: 1rem;
		line-height: 1.6;
	}
</style>
