---
import Layout from '../layouts/Layout.astro';

// Use import.meta.glob to find all markdown files
const docs = import.meta.glob('../docs/**/*.md', { eager: true });

interface DocInfo {
  title: string;
  slug: string;
  domain: string;
}

const allDocs: DocInfo[] = Object.keys(docs).map((path) => {
  const slug = path.replace('../docs/', '').replace('.md', '');
  const domain = slug.split('/')[0];
  const fm = (docs[path] as any).frontmatter;
  return {
    title: fm.title || slug.split('/').pop(),
    slug,
    domain,
  };
});

// Group by domain
const groupedDocs = allDocs.reduce((acc, doc) => {
  if (!acc[doc.domain]) {
    acc[doc.domain] = [];
  }
  acc[doc.domain].push(doc);
  return acc;
}, {} as Record<string, DocInfo[]>);

const sortedDomains = Object.keys(groupedDocs).sort();
---

<Layout title="Knowledge for the AI Era">
	<section class="hero">
		<h1 class="hero-title">Knowledge for the <span class="gradient-text">AI Era</span></h1>
		<p class="hero-subtitle">The first imposing, serverless documentation repository optimized for both humans and agents.</p>
		<div class="hero-cta">
			<a href="/search" class="btn-fluent main-cta">
				<i class="fa-solid fa-magnifying-glass"></i> Search Knowledge
			</a>
		</div>
	</section>

	<section class="domains">
		<div class="section-header">
			<h2 class="fluent-h2">Knowledge Repositories</h2>
			<p class="section-desc">Indexed documentation domains ready for agents.</p>
		</div>

		<div class="grid">
			{sortedDomains.map((domain) => (
				<div class="repo-card">
					<div class="repo-header">
						<div class="repo-icon">
							<img src={"https://www.google.com/s2/favicons?domain=" + domain + "&sz=64"} alt={domain} class="favicon-img" />
						</div>
						<div class="repo-meta">
							<h3 class="repo-title">{domain}</h3>
							<span class="repo-count">{groupedDocs[domain].length} resources</span>
						</div>
					</div>
					<div class="repo-links">
						<a href={"/doc/" + domain + "/_index"} class="repo-link-btn">
							<i class="fa-solid fa-list-ul"></i> Explore Index
						</a>
						<a href={"https://" + domain} target="_blank" class="repo-link-btn secondary">
							<i class="fa-solid fa-external-link-square-alt"></i> Original Site
						</a>
					</div>
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
	.hero {
		text-align: center;
		padding: 4rem 0 6rem;
	}

	.hero-title {
		font-size: 5rem;
		font-weight: 800;
		letter-spacing: -2px;
		margin-bottom: 1.5rem;
		line-height: 1.1;
	}

	.gradient-text {
		background: linear-gradient(135deg, #F5833E 0%, #FFC107 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.hero-subtitle {
		font-size: 1.4rem;
		color: var(--text-secondary);
		max-width: 700px;
		margin: 0 auto 3rem;
		font-weight: 500;
	}

    .main-cta {
        padding: 1.25rem 3rem;
        font-size: 1.1rem;
    }

	.section-header {
		margin-bottom: 3rem;
	}

	.fluent-h2 {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
	}

	.section-desc {
		font-size: 1.1rem;
		color: var(--text-secondary);
		font-weight: 600;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 2.5rem;
	}

	.repo-card {
		background: var(--bg-glass);
		backdrop-filter: blur(30px);
		border: 1px solid var(--border-glass);
		padding: 2rem;
		border-radius: 32px;
		transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
		box-shadow: var(--shadow-soft);
	}

	.repo-card:hover {
		transform: translateY(-10px) scale(1.01);
		box-shadow: 0 40px 80px rgba(0,0,0,0.1);
		border-color: var(--primary);
	}

	.repo-header {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		margin-bottom: 1.5rem;
	}

	.repo-icon {
		width: 56px;
		height: 56px;
		background: white;
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 8px 16px rgba(0,0,0,0.05);
		overflow: hidden;
		flex-shrink: 0;
	}

	.favicon-img {
		width: 32px;
		height: 32px;
	}

	.repo-title {
		font-size: 1.25rem;
		font-weight: 800;
		margin: 0;
        word-break: break-all;
	}

	.repo-count {
		font-size: 0.85rem;
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.repo-links {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.repo-link-btn {
		background: rgba(0, 0, 0, 0.04);
		color: var(--text-main);
		padding: 0.85rem;
		border-radius: 16px;
		text-decoration: none;
		font-weight: 700;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		transition: all 0.2s;
        font-size: 0.95rem;
	}

	.repo-link-btn:hover {
		background: var(--primary);
		color: white;
	}

	.repo-link-btn.secondary {
		background: transparent;
		border: 1px solid rgba(0,0,0,0.08);
	}

	.repo-link-btn.secondary:hover {
		background: rgba(0,0,0,0.02);
		color: var(--primary);
		border-color: var(--primary);
	}

	@media (max-width: 800px) {
		.hero-title { font-size: 3rem; letter-spacing: -1px; }
        .hero-subtitle { font-size: 1.1rem; }
        .hero { padding: 3rem 0; }
        .fluent-h2 { font-size: 2rem; }
		.grid { grid-template-columns: 1fr; gap: 1.5rem; }
        .repo-card { padding: 1.5rem; }
	}
</style>
