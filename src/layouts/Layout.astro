---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="https://hosted.inled.es/mdpedia.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | MDPEDIA</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
	</head>
	<body>
		<div class="background-blobs">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
		</div>
		<header>
			<nav>
				<a href="/" class="logo-link">
					<img src="https://hosted.inled.es/mdpedia.png" alt="MDPEDIA Logo" class="logo-img" width="40" height="40" />
					<span class="logo-text">MDPEDIA</span>
				</a>
			</nav>
		</header>
		<main>
			<div class="glass-container">
				<slot />
			</div>
		</main>
		<footer>
			<p>© 2024 MDPEDIA — Knowledge for the AI Era</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--primary: #F5833E;
		--primary-hover: #e0722e;
		--bg-color: #fafafa;
		--text-main: #1c1c1c;
		--text-secondary: #5a5a5a;
		--glass-bg: rgba(255, 255, 255, 0.7);
		--glass-border: rgba(255, 255, 255, 0.4);
		--shadow-fluent: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
		--font-family: 'Plus Jakarta Sans', sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	body {
		font-family: var(--font-family);
		background-color: var(--bg-color);
		color: var(--text-main);
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		overflow-x: hidden;
		position: relative;
	}

	.background-blobs {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		overflow: hidden;
		filter: blur(80px);
		opacity: 0.4;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		background: var(--primary);
	}

	.blob-1 {
		width: 400px;
		height: 400px;
		top: -100px;
		right: -100px;
		opacity: 0.5;
	}

	.blob-2 {
		width: 300px;
		height: 300px;
		bottom: -50px;
		left: -50px;
		background: #ffb38a;
		opacity: 0.4;
	}

	header {
		padding: 1.5rem 2rem;
		display: flex;
		justify-content: center;
		z-index: 10;
	}

	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		color: var(--text-main);
		transition: transform 0.2s;
	}

	.logo-link:hover {
		transform: translateY(-2px);
	}

	.logo-img {
		width: 40px !important;
		height: 40px !important;
		min-width: 40px;
		min-height: 40px;
		object-fit: contain;
	}

	.logo-text {
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: -0.5px;
	}

	main {
		flex: 1;
		padding: 1rem 2rem 4rem;
		max-width: 1000px;
		margin: 0 auto;
		width: 100%;
		z-index: 1;
	}

	.glass-container {
		background: var(--glass-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-radius: 24px;
		border: 1px solid var(--glass-border);
		box-shadow: var(--shadow-fluent);
		padding: 3rem;
		min-height: 60vh;
	}

	footer {
		padding: 2rem;
		text-align: center;
		font-size: 0.9rem;
		color: var(--text-secondary);
	}

	h1, h2, h3 {
		letter-spacing: -0.5px;
	}

	a {
		color: var(--primary);
		text-decoration: none;
		font-weight: 600;
	}

	a:hover {
		color: var(--primary-hover);
	}

	/* Fluent-like button utility */
	.btn-fluent {
		background: var(--primary);
		color: white;
		border: none;
		padding: 0.75rem 1.5rem;
		border-radius: 12px;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 4px 12px rgba(245, 131, 62, 0.2);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.btn-fluent:hover {
		background: var(--primary-hover);
		transform: translateY(-2px);
		box-shadow: 0 6px 16px rgba(245, 131, 62, 0.3);
		color: white;
	}

	.btn-fluent:active {
		transform: translateY(0);
	}
</style>
